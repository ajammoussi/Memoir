# Memoir Personal Assistant - Environment Configuration
# Copy this file to .env and configure your settings

# ============================================================================
# Watch Folders
# ============================================================================
# Comma-separated list of directories to monitor
# Example: WATCH_FOLDERS=/home/user/Documents,/home/user/Downloads
WATCH_FOLDERS=

# ============================================================================
# Google Drive Integration
# ============================================================================
# For monitoring public Google Drive folders
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Enable the Google Drive API for your project
# Example: GOOGLE_API_KEY=AIzaSyAxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_API_KEY=

# (Optional) For OAuth-based Drive sync
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_CREDENTIALS=credentials.json
GOOGLE_DRIVE_TOKEN=token.pickle

# ============================================================================
# OneDrive Integration (Optional)
# ============================================================================
ONEDRIVE_ENABLED=false
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=

# ============================================================================
# LLM Configuration
# ============================================================================
# Choose a model <4B parameters
# Options:
#   - microsoft/phi-3-mini-4k-instruct (3.8B) - Recommended
#   - stabilityai/stablelm-3b-4e1t (3B)
#   - Qwen/Qwen1.5-1.8B (1.8B)
#   - TinyLlama/TinyLlama-1.1B-Chat-v1.0 (1.1B)
LLM_MODEL=microsoft/phi-3-mini-4k-instruct

# ============================================================================
# Processing Configuration
# ============================================================================
# Enable CUDA for GPU acceleration (if available)
CUDA_AVAILABLE=false

# ============================================================================
# Logging
# ============================================================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# API Server
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================================
# Development Settings
# ============================================================================
# Enable hot reload in development
DEV_MODE=false
