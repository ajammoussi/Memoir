HF_TOKEN=

# Enable caption/transcription generation for images and audio
GENERATE_MEDIA_TEXT=True

# Ollama model for summarization/keywords (run: ollama pull llama3.2)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=memoir_embeddings

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=memoir_user
POSTGRES_PASSWORD=memoir_password
POSTGRES_DB=memoir

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# VLM (server | inline)
VLM_MODE=server
VLM_SERVER_URL=http://127.0.0.1:5000/analyze